<!DOCTYPE html>
<meta charset="utf-8">
<style>
  body {
    font-family: sans-serif;
  }
  .axis path,
  .axis line {
    fill: none;
    stroke: #000;
    shape-rendering: crispEdges;
  }
  .legend {
    font-size: 12px;
  }
</style>
<body>

<script src="https://d3js.org/d3.v3.min.js"></script>
<script>
  // 1. Setup SVG dimensions and margins
  var margin = {top: 20, right: 80, bottom: 30, left: 40},
      width = 600 - margin.left - margin.right,
      height = 400 - margin.top - margin.bottom;

  // 2. Setup v3 scales
  var x = d3.scale.ordinal()
      .rangeRoundBands([0, width], .1);

  var y = d3.scale.linear()
      .rangeRound([height, 0]);

  var color = d3.scale.category10();

  // 3. Setup v3 axes
  var xAxis = d3.svg.axis()
      .scale(x)
      .orient("bottom");

  var yAxis = d3.svg.axis()
      .scale(y)
      .orient("left")
      .tickFormat(d3.format(".0s"));

  // 4. Append the SVG object to the body
  var svg = d3.select("body").append("svg")
      .attr("width", width + margin.left + margin.right)
      .attr("height", height + margin.top + margin.bottom)
    .append("g")
      .attr("transform", "translate(" + margin.left + "," + margin.top + ")");

  // 5. Sample Data
  var data = [
    { category: "Q1", ProductA: 20, ProductB: 10, ProductC: 15 },
    { category: "Q2", ProductA: 15, ProductB: 20, ProductC: 10 },
    { category: "Q3", ProductA: 30, ProductB: 15, ProductC: 25 },
    { category: "Q4", ProductA: 25, ProductB: 30, ProductC: 20 }
  ];

  // 6. Data Processing for Stacking
  // Extract the keys for the stack (ignoring the x-axis category)
  color.domain(d3.keys(data[0]).filter(function(key) { return key !== "category"; }));

  // Calculate the y0 (start) and y1 (end) positions for each segment
  data.forEach(function(d) {
    var y0 = 0;
    d.segments = color.domain().map(function(name) { 
      return {name: name, y0: y0, y1: y0 += +d[name]}; 
    });
    d.total = d.segments[d.segments.length - 1].y1;
  });

  // 7. Set domains based on processed data
  x.domain(data.map(function(d) { return d.category; }));
  y.domain([0, d3.max(data, function(d) { return d.total; })]);

  // 8. Draw Axes
  svg.append("g")
      .attr("class", "x axis")
      .attr("transform", "translate(0," + height + ")")
      .call(xAxis);

  svg.append("g")
      .attr("class", "y axis")
      .call(yAxis)
    .append("text")
      .attr("transform", "rotate(-90)")
      .attr("y", 6)
      .attr("dy", ".71em")
      .style("text-anchor", "end")
      .text("Sales");

  // 9. Draw the Stacked Bars
  var categoryGroup = svg.selectAll(".category")
      .data(data)
    .enter().append("g")
      .attr("class", "category")
      .attr("transform", function(d) { return "translate(" + x(d.category) + ",0)"; });

  categoryGroup.selectAll("rect")
      .data(function(d) { return d.segments; })
    .enter().append("rect")
      .attr("width", x.rangeBand())
      .attr("y", function(d) { return y(d.y1); })
      .attr("height", function(d) { return y(d.y0) - y(d.y1); })
      .style("fill", function(d) { return color(d.name); });

  // 10. Draw Legend
  var legend = svg.selectAll(".legend")
      .data(color.domain().slice().reverse())
    .enter().append("g")
      .attr("class", "legend")
      .attr("transform", function(d, i) { return "translate(0," + i * 20 + ")"; });

  legend.append("rect")
      .attr("x", width + 50)
      .attr("width", 18)
      .attr("height", 18)
      .style("fill", color);

  legend.append("text")
      .attr("x", width + 44)
      .attr("y", 9)
      .attr("dy", ".35em")
      .style("text-anchor", "end")
      .text(function(d) { return d; });

</script>
</body>
